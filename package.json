{
  "name": "@otohime-site/parser",
  "version": "26.4.0",
  "license": "MIT",
  "type": "module",
  "types": "index.d.ts",
  "homepage": "https://github.com/otohime-site/parser#readme",
  "repository": "github:otohime-site/parser",
  "exports": {
    ".": "./index.js",
    "./dx_intl": "./dx_intl/index.js",
    "./dx_intl/*": "./dx_intl/*.js"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "lint": "eslint",
    "test": "vitest run --coverage",
    "build": "rm -rf dist/ && tsc && cp README.md dist/ && jq 'del(.scripts.prepare)' package.json > dist/package.json",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/eslint-plugin": "^1.6.16",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.js,*.ts": "eslint --cache --fix",
    "*.{js,ts,css,md}": "prettier --write"
  }
}
